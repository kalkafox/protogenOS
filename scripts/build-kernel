#!/usr/bin/env bash
set -euo pipefail

project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
image_name="${PROTOGENOS_KERNEL_IMAGE:-protogenos-kernel-builder}"
arch_image="${PROTOGENOS_KERNEL_ARCH_IMAGE:-archlinux:base-devel}"

usage() {
    echo "Usage: $0 [--list|--check] [--preflight] FLAVOR" >&2
}

if [[ "${1:-}" == "--list" ]]; then
    for config in "${project_root}"/kernels/flavors/*.cfg; do
        basename "${config}" .cfg
    done
    exit 0
fi

if [[ "${1:-}" == "--check" ]]; then
    exec "${project_root}/scripts/check-kernel-configs"
fi

preflight=false
if [[ "${1:-}" == "--preflight" ]]; then
    preflight=true
    shift
fi

if [[ $# -ne 1 ]]; then
    usage
    exit 2
fi

flavor="$1"
if [[ ! "${flavor}" =~ ^[a-z0-9-]+$ ]] || \
    [[ ! -f "${project_root}/kernels/flavors/${flavor}.cfg" ]]; then
    echo "Unknown kernel flavor: ${flavor}" >&2
    usage
    exit 2
fi

if ! command -v docker >/dev/null 2>&1; then
    echo "Docker was not found." >&2
    exit 1
fi

mkdir -p "${project_root}/kernels/out/${flavor}"

docker buildx build --load \
    --build-arg "ARCH_IMAGE=${arch_image}" \
    --tag "${image_name}" \
    --file "${project_root}/docker/Kernel.Dockerfile" \
    "${project_root}"

docker run --rm \
    --env "HOST_UID=$(id -u)" \
    --env "HOST_GID=$(id -g)" \
    --env "PROTOGENOS_KERNEL_PREFLIGHT=${preflight}" \
    --mount "type=bind,src=${project_root},dst=/workspace,readonly" \
    --mount "type=bind,src=${project_root}/kernels/out/${flavor},dst=/output" \
    "${image_name}" \
    /workspace/scripts/container-build-kernel "${flavor}"
