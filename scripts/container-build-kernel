#!/usr/bin/env bash
set -euo pipefail

project_root="/workspace"
flavor="${1:-}"
config="${project_root}/kernels/flavors/${flavor}.cfg"
lock_file="${project_root}/kernels/linux-tkg.lock"

if [[ ! "${flavor}" =~ ^[a-z0-9-]+$ ]] || [[ ! -f "${config}" ]]; then
    echo "Unknown kernel flavor: ${flavor}" >&2
    exit 2
fi

# This file is project-owned build input, not user-provided shell data.
source "${lock_file}"

build_uid="${HOST_UID:-1000}"
build_gid="${HOST_GID:-1000}"
if [[ "${build_uid}" == "0" ]]; then
    build_uid=1000
fi
if [[ "${build_gid}" == "0" ]]; then
    build_gid=1000
fi

groupadd --gid "${build_gid}" builder
useradd --uid "${build_uid}" --gid "${build_gid}" --create-home builder
install -d -o builder -g builder /build /output /home/builder/.config/frogminer
install -m 0644 -o builder -g builder \
    "${config}" /home/builder/.config/frogminer/linux-tkg.cfg

sudo -u builder git clone "${LINUX_TKG_REPOSITORY}" /build/linux-tkg
sudo -u builder git -C /build/linux-tkg checkout --detach "${LINUX_TKG_REVISION}"

actual_revision="$(sudo -u builder git -C /build/linux-tkg rev-parse HEAD)"
if [[ "${actual_revision}" != "${LINUX_TKG_REVISION}" ]]; then
    echo "linux-tkg revision mismatch" >&2
    exit 1
fi
if ! grep -Fxq "_version=\"${LINUX_VERSION}\"" "${config}"; then
    echo "${config} does not match ${LINUX_VERSION} from the lock file" >&2
    exit 1
fi

if [[ "${PROTOGENOS_KERNEL_PREFLIGHT:-false}" == "true" ]]; then
    echo "Kernel builder preflight passed for ${flavor} at ${actual_revision}."
    chown -R "${HOST_UID:-0}:${HOST_GID:-0}" /output
    exit 0
fi

(
    cd /build/linux-tkg
    sudo -u builder env HOME=/home/builder makepkg --cleanbuild --noconfirm
)

find /build/linux-tkg -maxdepth 1 -type f -name '*.pkg.tar.*' \
    -exec cp --target-directory=/output {} +
if ! find /output -maxdepth 1 -type f -name '*.pkg.tar.*' -print -quit | grep -q .; then
    echo "linux-tkg did not produce packages" >&2
    exit 1
fi

(
    cd /output
    sha256sum -- *.pkg.tar.* > SHA256SUMS
)
chown -R "${HOST_UID:-0}:${HOST_GID:-0}" /output
