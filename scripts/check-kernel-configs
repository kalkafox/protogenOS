#!/usr/bin/env bash
set -euo pipefail

project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
lock_file="${project_root}/kernels/linux-tkg.lock"
flavors_dir="${project_root}/kernels/flavors"

# These files are project-owned build inputs, not user-provided shell data.
source "${lock_file}"

if [[ ! "${LINUX_TKG_REVISION}" =~ ^[0-9a-f]{40}$ ]]; then
    echo "linux-tkg revision must be a full 40-character commit" >&2
    exit 1
fi
if [[ ! "${LINUX_VERSION}" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "kernel version must be a full vX.Y.Z tag" >&2
    exit 1
fi

declare -A package_names=()
count=0
for config in "${flavors_dir}"/*.cfg; do
    unset _version _custom_pkgbase _cpusched _compiler _processor_opt
    unset _kernel_on_diet _nofallback
    source "${config}"

    flavor="$(basename "${config}" .cfg)"
    expected_pkgbase="linux-protogenos-${flavor}"
    if [[ "${_version:-}" != "${LINUX_VERSION}" ]]; then
        echo "${flavor}: version does not match linux-tkg.lock" >&2
        exit 1
    fi
    if [[ "${_custom_pkgbase:-}" != "${expected_pkgbase}" ]]; then
        echo "${flavor}: package base must be ${expected_pkgbase}" >&2
        exit 1
    fi
    if [[ -n "${package_names[${_custom_pkgbase}]:-}" ]]; then
        echo "${flavor}: duplicate package base ${_custom_pkgbase}" >&2
        exit 1
    fi
    package_names["${_custom_pkgbase}"]="${flavor}"
    if [[ ! "${_cpusched:-}" =~ ^(eevdf|bore|pds|bmq)$ ]]; then
        echo "${flavor}: unsupported scheduler ${_cpusched:-unset}" >&2
        exit 1
    fi
    if [[ "${_compiler:-}" != "gcc" ]]; then
        echo "${flavor}: only the supported GCC toolchain is enabled" >&2
        exit 1
    fi
    if [[ "${_processor_opt:-}" != "x86-64" ]]; then
        echo "${flavor}: distributed kernels must target x86-64" >&2
        exit 1
    fi
    if [[ "${_nofallback:-}" != "true" ]]; then
        echo "${flavor}: linux-tkg must fail instead of prompting" >&2
        exit 1
    fi
    if [[ "${flavor}" == "minimal-vm" ]]; then
        [[ "${_kernel_on_diet:-}" == "true" ]] || {
            echo "minimal-vm: diet mode must be enabled" >&2
            exit 1
        }
    elif [[ "${_kernel_on_diet:-}" != "false" ]]; then
        echo "${flavor}: diet mode is only allowed for minimal-vm" >&2
        exit 1
    fi
    count=$((count + 1))
done

if [[ "${count}" -ne 5 ]]; then
    echo "expected 5 kernel flavors, found ${count}" >&2
    exit 1
fi

echo "Kernel configuration checks passed (${count} flavors, ${LINUX_VERSION})."
