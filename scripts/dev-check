#!/usr/bin/env bash
set -euo pipefail

project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${project_root}"

export PYTHONPATH="${project_root}/installer${PYTHONPATH:+:${PYTHONPATH}}"
python -m unittest discover -s tests -v
bash -n scripts/*
zsh -n overlays/airootfs/usr/local/share/protogenos/zlogin
git diff --check

echo "Development checks passed."
